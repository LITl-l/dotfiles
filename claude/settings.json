{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Explorer",
      "WebFetch",
      "WebSearch",
      "Skill",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(env)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git fetch:*)",
      "Bash(git worktree:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(jj:*)",
      "Bash(nix flake check:*)",
      "Bash(nix eval:*)",
      "Bash(nix search:*)",
      "Bash(nix build:*)",
      "Bash(nix path-info:*)",
      "Bash(nix derivation:*)",
      "Bash(nix-instantiate:*)",
      "Bash(home-manager switch:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(gh auth:*)",
      "Bash(gh repo view:*)",
      "Bash(direnv:*)",
      "Bash(fish:*)"
    ],
    "deny": [
      "Bash(rm -rf ~)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(sudo rm:*)",
      "Bash(chmod -R 777:*)",
      "Bash(nix-collect-garbage:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(jj git push:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh api:*)",
      "Bash(nix flake update:*)"
    ],
    "defaultMode": "auto"
  },
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "high"
  },
  "showThinkingSummaries": true,
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/stop-phrase-guard.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/stop-hook-git-check.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-code-plugins": true,
    "context7@claude-code-plugins": true,
    "feature-dev@claude-code-plugins": true,
    "playwright@claude-code-plugins": true,
    "security-guidance@claude-code-plugins": true,
    "ralph-wiggum@claude-code-plugins": true,
    "hookify@claude-code-plugins": true,
    "jj-master@local": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "skipAutoPermissionPrompt": true,
  "additionalDirectories": [
    "~/wkspace/**",
    "~/.config/dotfiles/**"
  ]
}
